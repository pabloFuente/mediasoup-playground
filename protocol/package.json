  },
  "devDependencies": {
    "@bufbuild/buf": "1.68.4",
    "@bufbuild/protobuf": "2.11.0",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "cjs-to-es6": "2.0.1",
    "fix-esm-import-path": "1.10.3",
    "ts-proto": "2.11.6"
  }
}
