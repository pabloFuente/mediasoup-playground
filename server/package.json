{
  "name": "mediasoup-server",
  "version": "1.0.0",
  "type": "module",
  "exports": "./index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node --loader ts-node/esm src/index.ts",
    "dev": "npx nodemon",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "npx tsc",
    "build:bundle": "npm run build && npx esbuild dist/src/index.js --bundle --platform=node --minify --outfile=out/index.cjs",
    "build:binary": "mkdir -p bin && npm run build:bundle && node --experimental-sea-config sea-config.json && cp $(command -v node) bin/mediasoup-server && npx postject bin/mediasoup-server NODE_SEA_BLOB bin/sea-prep.blob --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2 && rm bin/sea-prep.blob",
    "lint": "npx eslint --fix",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check ."
  },
  "author": "https://github.com/pabloFuente",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@eslint/compat": "2.0.5",
    "async-lock": "1.4.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "lodash": "4.18.1",
    "mediasoup": "3.19.21",
    "semver": "^7.7.4",
    "socket.io": "4.8.3",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/async-lock": "1.4.2",
    "@types/express": "5.0.6",
    "@types/jest": "29.5.14",
    "@types/lodash": "4.17.24",
    "@types/node": "25.6.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm run test && npm run test:coverage && npm run format"
    }
  }
}
